{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"baseUrl": "../..",
		"composite": true,
		"outDir": "./dist",
		"declaration": true,
		"emitDeclarationOnly": true,
		"noEmit": false,
		"rootDir": "../",
		"paths": {
			"@virtual-os/core": ["packages/core/src/main"],
			"@virtual-os/shared": ["packages/shared/src/main"],
			"@virtual-os/*": ["packages/apps/*/src/main"]
		}
	},
	"include": ["src", "../core/src", "../shared/src", "../apps/**/src", "vite.config.ts"],
	"exclude": ["node_modules"]
}